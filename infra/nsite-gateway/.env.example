# Copy to .env (gitignored via root .gitignore) and adjust.

# Canonical URL for links on the built-in homepage / status (use https in production).
PUBLIC_DOMAIN=http://localhost:3040

# Relays used to resolve user NIP-65 / blossom hints (comma-separated, no spaces).
LOOKUP_RELAYS=wss://user.kindpag.es,wss://purplepag.es

# Extra relays merged into every manifest query (comma-separated, no spaces).
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net,wss://relay.nostr.band

# Fallback Blossom servers when the user has no kind 10063 list (comma-separated).
BLOSSOM_SERVERS=https://blossom.band,https://nostr.download

# Optional: local flower-cache / BUD-11 proxy (omit for a minimal stack).
# BLOSSOM_PROXY=http://blossom:24242

# Cache TTL (seconds); see upstream README for full table.
CACHE_TIME=3600
