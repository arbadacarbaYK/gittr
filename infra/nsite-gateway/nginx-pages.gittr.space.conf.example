# Merge into /etc/nginx/sites-available/gittr (or a separate file + include).
#
# Order of operations:
#   1. DNS: pages.gittr.space → this server
#   2. Docker gateway on 127.0.0.1:3040 (./scripts/deploy-nsite-gateway.sh)
#   3. Add this server { } block, then: sudo nginx -t && sudo systemctl reload nginx
#   4. TLS: sudo certbot --nginx -d pages.gittr.space
#      (certbot will extend this block with ssl_certificate lines)

server {
    listen 80;
    server_name pages.gittr.space;

    location / {
        proxy_pass http://127.0.0.1:3040;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}
