# Production values for gittr Pages (nsite gateway) on Hetzner.
# Deployed to /opt/ngit/infra/nsite-gateway/.env by scripts/deploy-nsite-gateway.sh
# (no secrets — relay URLs and public gateway URL only).

PUBLIC_DOMAIN=https://pages.gittr.space
LOOKUP_RELAYS=wss://user.kindpag.es,wss://purplepag.es
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net,wss://relay.nostr.band,wss://nsite.run
BLOSSOM_SERVERS=https://blossom.band,https://nostr.download
CACHE_TIME=3600
NSITE_HOST=0.0.0.0
NSITE_PORT=3000
CACHE_PATH=/cache/nsite-gateway.kv
