# Production values for gittr Pages (nsite gateway).
# `scripts/deploy-nsite-gateway.sh` installs this file as `.env` in the gateway directory on the host (see REMOTE in that script).
# (no secrets — relay URLs and public gateway URL only).

# Hostname only (v3.6.1+ root-host check); not a full URL
PUBLIC_DOMAIN=pages.gittr.space
LOOKUP_RELAYS=wss://user.kindpag.es,wss://purplepag.es
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net,wss://relay.nostr.band,wss://nsite.run
BLOSSOM_SERVERS=https://blossom.band,https://nostr.download
CACHE_TIME=3600
NSITE_HOST=0.0.0.0
NSITE_PORT=3000
CACHE_PATH=/cache/nsite-gateway.kv

# gittr operator (gittr@gittr.space) — loads NIP-51 kind 10000 mute list from relays.
# Deploy also sets GITTR_SYNC_MUTED_PUBKEYS from ui/.env.local blocklist (not in git).
CURATION_USER=9f07e82e3af121ec0172233d5eff87a914f28a0e3bba809983fc5050299900b8
CURATION_REFRESH=600
