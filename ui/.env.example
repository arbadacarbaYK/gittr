# gittr Environment Variables
# Copy this file to ui/.env.local and fill in your values

# ============================================
# Nostr Relays Configuration
# ============================================
# Comma-separated list of Nostr relay URLs (WSS protocol)
# These relays are used for repository discovery, issues, PRs, and other Nostr events
NEXT_PUBLIC_NOSTR_RELAYS=wss://git.shakespeare.diy,wss://ngit-relay.nostrver.se,wss://git-01.uid.ovh,wss://git-02.uid.ovh,wss://relay.ngit.dev,wss://ngit.danconwaydev.com,wss://relay.damus.io,wss://nos.lol,wss://relay.azzamo.net,wss://relay.nostr.band,wss://nostr.mom,wss://nostr.wine,wss://relay.snort.social,wss://relay.nostr.info,wss://relay.nostrgraph.net,wss://nostrue.com,wss://relay.noderunners.network,wss://nostr.fmt.wiz.biz,wss://relay.nostrich.land,wss://relay.current.fyi,wss://relay.nostr.bg,wss://nostr-relay.wlvs.space
# Server-only: set to 1 for CI/offline builds so sitemap skips live relay queries (uses static routes + optional nostr-pushed-repos.txt only).
# SITEMAP_SKIP_NOSTR=1

# ============================================
# Blossom Storage Configuration (NIP-96)
# ============================================
# Blossom servers for Git pack/blob storage (NIP-96)
# Grasp protocol instances (gitnostr.com, relay.ngit.dev) also serve as Blossom servers
NEXT_PUBLIC_BLOSSOM_URL=https://blossom.band
# Additional Blossom servers (comma-separated, optional)
# NEXT_PUBLIC_BLOSSOM_URLS=https://blossom.band,https://gitnostr.com,https://relay.ngit.dev

# GITHUB_PLATFORM_TOKEN=needed.against.rate.limiting

# Add these for notifications
# NOSTR_NSEC=platform.nsec
# TELEGRAM_BOT_TOKEN=notifications
# TELEGRAM_CHAT_ID=identity.match
# ============================================
# Domain Configuration
# ============================================
# Your platform domain (e.g., gittr.space)
NEXT_PUBLIC_DOMAIN=gittr.space
# Git SSH base hostname for clone URLs (e.g., gittr.space)
NEXT_PUBLIC_GIT_SSH_BASE=gittr.space
# Git server URL for repository clone tags (defaults to https://${NEXT_PUBLIC_DOMAIN})
NEXT_PUBLIC_GIT_SERVER_URL=https://git.gittr.space

NEXT_PUBLIC_SITE_URL=https://gittr.space

# gittr Pages (NIP-5A nsite gateway) — public URL for in-app /pages links (no trailing slash)
NEXT_PUBLIC_GITTR_PAGES_URL=https://pages.gittr.space
# Directory cards: live snapshot backgrounds via image.thum.io (set to 0 to disable third-party previews)
# NEXT_PUBLIC_PAGES_CARD_PREVIEW=0

NEXT_PUBLIC_PLATFORM_PUBKEY=yourplatformpubkey4nip05andNIP11endpoint

# ============================================
# git-nostr-bridge (push paywall / RepositoryPushPolicy)
# ============================================
# If Next.js and the bridge run as different users, set this to the bridge SQLite path
# (must match DbFile in git-nostr-bridge.json). Otherwise resolution uses
# /home/git-nostr/.config/... before $HOME/.config/...
# GIT_NOSTR_BRIDGE_DB=/home/git-nostr/.config/git-nostr/git-nostr-db.sqlite
#
# Absolute path to bare repos on disk (same as repositoryDir in git-nostr-bridge.json).
# Used by GET /api/nostr/repo/files. Set when Next.js runs as a user whose $HOME config
# does not point at the bridge’s repo tree.
# GIT_NOSTR_BRIDGE_REPOS_DIR=/home/git-nostr/git-nostr-repositories